# 複製本檔為 .env 並填入實際金鑰（.env 已被 .gitignore 排除，請勿提交）

# YouTube Data API v3 金鑰
YOUTUBE_API_KEY=

# LLM 統一走 OpenRouter（OpenAI 相容 API）
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=anthropic/claude-sonnet-4.5

# LINE Messaging API
LINE_CHANNEL_ACCESS_TOKEN=
LINE_USER_ID=

# Supabase 知識庫（本機 + Streamlit Cloud 共用）
SUPABASE_URL=
SUPABASE_KEY=
