# Copy this file to .env and fill in the credentials you need.

# YouTube Data API v3
YOUTUBE_API_KEY=

# Apify actors for Instagram, Facebook, and Threads
APIFY_API_TOKEN=
APIFY_INSTAGRAM_ACTOR=apify/instagram-scraper
APIFY_FACEBOOK_ACTOR=apify/facebook-videos-scraper
APIFY_THREADS_ACTOR=apify/threads-scraper

# OpenRouter, using the OpenAI-compatible SDK
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=anthropic/claude-sonnet-4.5

# LINE Messaging API
LINE_CHANNEL_ACCESS_TOKEN=
LINE_USER_ID=

# Supabase, optional history storage
SUPABASE_URL=
SUPABASE_KEY=
